<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Prevent_Future_Installation_Dates</fullName>
    <active>true</active>
    <errorConditionFormula>Installation_Date__c &gt; TODAY()</errorConditionFormula>
    <errorMessage>The installation date cannot be in the future.</errorMessage>
</ValidationRule>
