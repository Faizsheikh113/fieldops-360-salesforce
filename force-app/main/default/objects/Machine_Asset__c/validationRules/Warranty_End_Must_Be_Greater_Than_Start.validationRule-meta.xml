<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Warranty_End_Must_Be_Greater_Than_Start</fullName>
    <active>true</active>
    <errorConditionFormula>Warranty_End__c &lt; Warranty_Start__c</errorConditionFormula>
    <errorMessage>Warranty End Date must be after Warranty Start Date.</errorMessage>
</ValidationRule>
