<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Closed_Tickets_Require_Resolution_Notes</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
   ISPICKVAL(Status__c, &quot;Closed&quot;),
   ISBLANK(Resolution_Notes__c)
)</errorConditionFormula>
    <errorMessage>Please fill in the Resolution Notes before closing the ticket.</errorMessage>
</ValidationRule>
